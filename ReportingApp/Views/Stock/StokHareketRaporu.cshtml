@model Reporting.Models.StockMovementReportViewModel

@{
    ViewData["Title"] = "Stok Hareket Raporu";
}

<div class="px-4 pb-8 md:px-24 md:pb-16">

    <div class="my-12 flex flex-row items-center justify-between">
        <div >
            <h1 class="kirmizi-baslik">Stok Hareket Raporu</h1>
            <p class="mt-1 text-sm text-slate-500">
                Seçilen tarih aralığında en çok ve en az hareket eden ürünler.
            </p>

        </div>


        <form method="get" class="flex flex-wrap gap-4">

            <div>
                <label class="mb-1 block text-sm font-semibold text-slate-700">Başlangıç Tarihi</label>
                <input type="date"
                       name="baslangicTarihi"
                       value="@Model.BaslangicTarihi.ToString("yyyy-MM-dd")"
                       class="rounded-lg border px-3 py-2 text-sm" />
            </div>

            <div>
                <label class="mb-1 block text-sm font-semibold text-slate-700">Bitiş Tarihi</label>
                <input type="date"
                       name="bitisTarihi"
                       value="@Model.BitisTarihi.ToString("yyyy-MM-dd")"
                       class="rounded-lg border px-3 py-2 text-sm" />
            </div>

            <button type="submit"
                    class="mt-5 rounded-lg bg-slate-800 px-4 text-sm font-semibold text-white">
                Filtrele
            </button>
            <a asp-controller="Stock"
               asp-action="StokHareketRaporuExcel"
               asp-route-baslangicTarihi="@Model.BaslangicTarihi.ToString("yyyy-MM-dd")"
               asp-route-bitisTarihi="@Model.BitisTarihi.ToString("yyyy-MM-dd")"
               class="mt-5 rounded-lg bg-green-600 px-4 py-2 text-sm font-semibold text-white hover:bg-green-700">
                Excel İndir
                <icon name="down" class="h-5 w-5 text-white"></icon>

            </a>
        </form>
    </div>
   

    <div class="mb-6 grid grid-cols-1 gap-4 md:grid-cols-4">

        <div class="flex flex-col justify-between rounded-2xl border border-slate-200 bg-purple-500 p-6 shadow-sm">
            <div class="text-base font-medium text-white">Hareket Gören Ürün</div>
            <div class="mt-3 text-3xl font-bold text-white">
                @Model.ToplamUrunSayisi
            </div>
        </div>

        <div class="flex flex-col justify-between rounded-2xl border border-slate-200 bg-green-500 p-6 shadow-sm">
            <div class="text-base font-medium text-white">Toplam Giriş</div>
            <div class="mt-3 text-3xl font-bold text-white">
                @Model.ToplamGiris.ToString("N2")
            </div>
        </div>

        <div class="flex flex-col justify-between rounded-2xl border border-slate-200 bg-red-500 p-6 shadow-sm">
            <div class="text-base font-medium text-white">Toplam Çıkış</div>
            <div class="mt-3 text-3xl font-bold text-white">
                @Model.ToplamCikis.ToString("N2")
            </div>
        </div>

        <div class="flex flex-col justify-between rounded-2xl border border-slate-200 bg-blue-500 p-6 shadow-sm">
            <div class="text-base font-medium text-white">Net Stok Değişimi</div>
            <div class="mt-3 text-3xl font-bold text-white">
                @Model.NetStokDegisimi.ToString("N2")
            </div>
        </div>

    </div>

    <div class="mb-6 bg-white shadow-sm">
        <partial name="_StockMovementTable"
            model="Model.EnCokGirisYapilanlar"
            view-data='new ViewDataDictionary(ViewData)
            {
                ["Baslik"] = "En Çok Giriş Yapılan Ürünler",
                     ["ColorClass"] = "text-green-600",
                     ["AnaKolon"] = "Net Değişim"
            }' />

        <partial name="_StockMovementTable"
            model="Model.EnCokCikisYapilanlar"
            view-data='new ViewDataDictionary(ViewData)
            {
                ["Baslik"] = "En Çok Çıkış Yapılan Ürünler",
             ["ColorClass"] = "text-red-600",
             ["AnaKolon"] = "Net Değişim"
            }' />

    </div>


</div>
