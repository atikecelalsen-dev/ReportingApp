@model Reporting.Models.CustomerProfitReportViewModel

@{
    string periyot = Model.Periyot ?? "aylik";

    string baslik =
        periyot == "haftalik" ? "Haftalık" :
        periyot == "gunluk" ? "Günlük" :
        periyot == "yillik" ? "Yıllık" :
        "Aylık";

    var top10Musteri = Model.Musteriler
        .OrderByDescending(x => x.Kar)
        .Take(10)
        .ToList();

    decimal maxKar = top10Musteri.Any() ? top10Musteri.Max(x => x.Kar) : 1;
}

<div>

    <div class="mb-8 flex items-center justify-between">
        <div>
            <p class="kirmizi-baslik">Müşteri Karlılık Raporu</p>
            <p class="mt-1 text-sm text-slate-500">
                Müşteri bazında satış, maliyet ve kar performansı.
            </p>
        </div>
    </div>

    <div class="mb-8 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">

        <div class="mb-5 flex items-center justify-between">
            <h2 class="text-lg font-bold text-slate-900">
                Cari Bazlı Ciro Dağılımı
            </h2>

            <span class="text-sm text-slate-500">
                İlk 5 müşteri
            </span>
        </div>

        <div class="grid grid-cols-1 gap-8 lg:grid-cols-[420px_1fr]">

            <div class="mx-auto h-[320px] w-[320px]">
                <canvas id="musteriChart"></canvas>
            </div>

            <div class="flex flex-col justify-center gap-5">

                @{
                    decimal toplamCiro = Model.Musteriler.Sum(x => x.Ciro);

                    var topMusteriler = Model.Musteriler
                        .OrderByDescending(x => x.Ciro)
                        .Take(5)
                        .ToList();

                    string[] renkler =
                    {
                    "bg-blue-500",
                    "bg-green-500",
                    "bg-yellow-400",
                    "bg-slate-400",
                    "bg-purple-500"
                };
                }

                @for (int i = 0; i < topMusteriler.Count; i++)
                {
                    var item = topMusteriler[i];

                    decimal oran = toplamCiro == 0
                        ? 0
                        : (item.Ciro / toplamCiro) * 100;

                    <div class="flex items-center justify-between gap-5">

                        <div class="flex items-center gap-4">

                            <div class="h-4 w-4 rounded-full @renkler[i]"></div>

                            <p class="text-sm font-semibold text-slate-700">
                                @item.CariAdi
                            </p>

                        </div>

                        <div class="text-right">

                            <p class="text-sm font-bold text-slate-900">
                                @item.Ciro.ToString("N2") ₺
                            </p>

                            <p class="text-xs text-slate-500">
                                (%@oran.ToString("N1"))
                            </p>

                        </div>

                    </div>
                }

            </div>

        </div>

    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <div class="mb-5 flex items-center justify-between">
            <h2 class="text-lg font-bold text-slate-900">Müşteri Detayları</h2>
            <span class="text-sm text-slate-500">@Model.Musteriler.Count müşteri</span>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b bg-slate-50 text-left text-xs uppercase text-black">
                        <th class="p-3">Cari Kodu</th>
                        <th class="p-3">Cari Adı</th>
                        <th class="p-3 text-right">Fatura</th>
                        <th class="p-3 text-right">Ciro</th>
                        <th class="p-3 text-right">Maliyet</th>
                        <th class="p-3 text-right">Kar</th>
                        <th class="p-3 text-right">Kar %</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model.Musteriler)
                    {
                        <tr class="border-b last:border-0 hover:bg-slate-50">
                            <td class="p-3 font-medium text-slate-700">@item.CariKodu</td>
                            <td class="p-3">@item.CariAdi</td>
                            <td class="p-3 text-right">@item.FaturaSayisi</td>
                            <td class="p-3 text-right">@item.Ciro.ToString("N2") ₺</td>
                            <td class="p-3 text-right">@item.Maliyet.ToString("N2") ₺</td>
                            <td class="p-3 text-right font-semibold text-blue-600">@item.Kar.ToString("N2") ₺</td>
                            <td class="p-3 text-right">%@item.KarOrani.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>


<script>

    const musteriCtx = document.getElementById('musteriChart');

    new Chart(musteriCtx, {

        type: 'doughnut',

        data: {

            labels: [
                    @Html.Raw(string.Join(",",
                            Model.Musteriler
                                    .OrderByDescending(x => x.Ciro)
                                    .Take(5)
                                    .Select(x => $"'{x.CariAdi}'")
            ))
                ],

            datasets: [{
                data: [
                        @string.Join(",",
                                Model.Musteriler
                                        .OrderByDescending(x => x.Ciro)
                                        .Take(5)
                                        .Select(x => x.Ciro.ToString(System.Globalization.CultureInfo.InvariantCulture))
                )
                    ],

                backgroundColor: [
                    '#3b82f6',
                    '#22c55e',
                    '#facc15',
                    '#94a3b8',
                    '#a855f7'
                ],

                borderWidth: 0
            }]
        },

        options: {

            responsive: true,
            maintainAspectRatio: false,

            cutout: '68%',

            plugins: {

                legend: {
                    display: false
                }

            }

        }

    });

</script>