@model Reporting.Models.SalesReportDashboardModel

@{
    string periyot = Model.Periyot ?? "gunluk";

    string baslik =
     periyot == "haftalik" ? "Haftalık" :
     periyot == "aylik" ? "Aylık" :
     periyot == "yillik" ? "Yıllık" :
     periyot == "gunluk" ? "Günlük" :
     "Özel tarihler için";

}

<div >

    <div class="mb-8 flex flex-row items-center justify-between">
        <div>
            <p class="kirmizi-baslik">Ciro Kar/Zarar Raporu</p>
            <p class="mt-1 text-sm text-slate-500">@baslik satış performansı.</p>
        </div>
        <a asp-controller="Home" 
        asp-action="SatisRaporuExcel"
           asp-route-periyot="@Model.Periyot"
           asp-route-BaslangicTarihi="@Context.Request.Query["BaslangicTarihi"]"
           asp-route-BitisTarihi="@Context.Request.Query["BitisTarihi"]"
           class="rounded-lg bg-green-600 px-4 py-2 text-sm font-semibold text-white hover:bg-green-700">
            Excel İndir
            <icon name="down" class="h-5 w-5 text-white"></icon>
        </a> 
    </div>




    <div class="my-8 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <div class="mb-5 flex items-center justify-between">
            <h2 class="text-lg font-bold text-slate-900">Döneme Göre Ciro</h2>
        </div>

        <div class="h-80">
            <canvas id="ciroChart"></canvas>
        </div>
    </div>



    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <div class="mb-5 flex items-center justify-between">
            <h2 class="text-lg font-bold text-slate-900">
                @baslik Satış, Maliyet ve Kar
            </h2>

            <span class="text-sm text-slate-500">
                @Model.RaporSatirlari.Count kayıt
            </span>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b bg-slate-50 text-left text-xs text-black uppercase">
                        <th class="p-3">Dönem</th>
                        <th class="p-3 text-right">Ciro</th>
                        <th class="p-3 text-right">Maliyet</th>
                        <th class="p-3 text-right">Kar</th>
                        <th class="p-3 text-right">Kar Oranı</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model.RaporSatirlari)
                    {
                        <tr class="border-b last:border-0 hover:bg-slate-50">
                            <td class="p-3 font-medium">@item.Baslik</td>
                            <td class="p-3 text-right">@item.Ciro.ToString("N2") ₺</td>
                            <td class="p-3 text-right">@item.Maliyet.ToString("N2") ₺</td>
                            <td class="p-3 text-right font-semibold text-blue-600">@item.Kar.ToString("N2") ₺</td>
                            <td class="p-3 text-right">%@item.KarOrani.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>


</div>
<script>
    const labels = [
                    @Html.Raw(string.Join(",", Model.RaporSatirlari
                                                    .OrderBy(x => x.Tarih)
                                                    .Select(x => $"'{x.Baslik}'")))
                ];

    const ciroData = [
                    @string.Join(",", Model.RaporSatirlari
                                                    .OrderBy(x => x.Tarih)
                                                    .Select(x => x.Ciro.ToString(System.Globalization.CultureInfo.InvariantCulture)))
                ];

    const maliyetData = [
                    @string.Join(",", Model.RaporSatirlari
                                                    .OrderBy(x => x.Tarih)
                                                    .Select(x => x.Maliyet.ToString(System.Globalization.CultureInfo.InvariantCulture)))
                ];

    const karData = [
                    @string.Join(",", Model.RaporSatirlari
                                                    .OrderBy(x => x.Tarih)
                                                    .Select(x => x.Kar.ToString(System.Globalization.CultureInfo.InvariantCulture)))
                ];

    const ctx = document.getElementById('ciroChart');

    new Chart(ctx, {
        type: 'line',

        data: {
            labels: labels,

            datasets: [

                {
                    label: 'Ciro (₺)',
                    data: ciroData,
                    borderColor: '#2563eb',
                    backgroundColor: 'rgba(37, 99, 235, 0.08)',
                    tension: 0.35,
                    fill: true,
                    borderWidth: 3,
                    pointRadius: 3
                },

                {
                    label: 'Maliyet (₺)',
                    data: maliyetData,
                    borderColor: '#ef4444',
                    backgroundColor: 'rgba(239, 68, 68, 0.05)',
                    tension: 0.35,
                    fill: false,
                    borderWidth: 3,
                    pointRadius: 3
                },

                {
                    label: 'Kar (₺)',
                    data: karData,
                    borderColor: '#22c55e',
                    backgroundColor: 'rgba(34, 197, 94, 0.05)',
                    tension: 0.35,
                    fill: false,
                    borderWidth: 3,
                    pointRadius: 3
                }

            ]
        },

        options: {
            responsive: true,
            maintainAspectRatio: false,

            plugins: {
                legend: {
                    position: 'bottom'
                }
            },

            scales: {
                y: {
                    ticks: {
                        callback: function (value) {
                            return value.toLocaleString('tr-TR') + ' ₺';
                        }
                    }
                }
            }
        }
    });
</script>