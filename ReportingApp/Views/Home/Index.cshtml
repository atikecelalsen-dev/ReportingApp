@using Reporting.Models
@model TumRaporlarViewModel

@{
    string periyot = Model.SatisRaporu.Periyot ?? "gunluk";

    string baslik =
    periyot == "haftalik" ? "Haftalık" :
    periyot == "aylik" ? "Aylık" :
    periyot == "yillik" ? "Yıllık" :
    "Günlük";

    SalesReportDashboardModel satisRaporu = Model.SatisRaporu;
}



<div class="scroll-smooth px-4 pb-8 md:px-24 md:pb-16">

    <div class="my-8 flex items-center justify-between">
        <div>
            <p class="kirmizi-yazi">Satış Raporları</p>
            <p class="h1-yazi !text-2xl !lg:text-3xl">@baslik satış performansı.</p>
        </div>

        <form method="get">
            <select name="periyot"
                    onchange="this.form.submit()"
                    class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 shadow-sm">
                <option value="gunluk" selected="@(periyot == "gunluk")">Günlük</option>
                <option value="haftalik" selected="@(periyot == "haftalik")">Haftalık</option>
                <option value="aylik" selected="@(periyot == "aylik")">Aylık</option>
                <option value="yillik" selected="@(periyot == "yillik")">Yıllık</option>
            </select>
        </form>
    </div>

    <div class="mb-8 grid grid-cols-1 gap-4 md:grid-cols-4">

        <div class="flex flex-row justify-between rounded-2xl border border-slate-200 bg-blue-500 p-6 shadow-sm">
            <div>
                <p class="text-base font-medium text-white">Toplam Satış</p>
                <p class="mt-3 text-3xl font-bold text-white">@satisRaporu.Ciro.Deger.ToString("N2") ₺</p>

                <div class="mt-2 flex flex-row items-center justify-start gap-3">
                    <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-white/20">
                        <icon name="@satisRaporu.Ciro.Icon" class="h-6 w-6 text-white"></icon>
                    </div>

                    <p class="text-sm font-medium text-white">
                        %@Math.Abs(satisRaporu.Ciro.DegisimOrani).ToString("N1")
                    </p>
                </div>

                <p class="text-sm font-medium text-white">Geçen döneme göre</p>
            </div>

            <div class="flex h-14 w-14 items-center justify-center rounded-full bg-white/20">
                <icon name="cart" class="h-6 w-6 text-white"></icon>
            </div>
        </div>

        <div class="flex flex-row justify-between rounded-2xl border border-slate-200 bg-rose-500 p-6 shadow-sm">
            <div>
                <p class="text-base font-medium text-white">Toplam Maliyet</p>
                <p class="mt-3 text-3xl font-bold text-white">@satisRaporu.Maliyet.Deger.ToString("N2") ₺</p>

                <div class="mt-2 flex flex-row items-center justify-start gap-3">
                    <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-white/20">
                        <icon name="@satisRaporu.Maliyet.Icon" class="h-6 w-6 text-white"></icon>
                    </div>

                    <p class="text-sm font-medium text-white">
                        %@Math.Abs(satisRaporu.Maliyet.DegisimOrani).ToString("N1")
                    </p>
                </div>

                <p class="text-sm font-medium text-white">Geçen döneme göre</p>
            </div>

            <div class="flex h-14 w-14 items-center justify-center rounded-full bg-white/20">
                <icon name="chart-pie" class="h-6 w-6 text-white"></icon>
            </div>
        </div>

        <div class="flex flex-row justify-between rounded-2xl border border-slate-200 bg-green-500 p-6 shadow-sm">
            <div>
                <p class="text-base font-medium text-white">Toplam Kar</p>
                <p class="mt-3 text-3xl font-bold text-white">@satisRaporu.Kar.Deger.ToString("N2") ₺</p>

                <div class="mt-2 flex flex-row items-center justify-start gap-3">
                    <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-white/20">
                        <icon name="@satisRaporu.Kar.Icon" class="h-6 w-6 text-white"></icon>
                    </div>

                    <p class="text-sm font-medium text-white">
                        %@Math.Abs(satisRaporu.Kar.DegisimOrani).ToString("N1")
                    </p>
                </div>

                <p class="text-sm font-medium text-white">Geçen döneme göre</p>
            </div>

            <div class="flex h-14 w-14 items-center justify-center rounded-full bg-white/20">
                <icon name="money" class="h-6 w-6 text-white"></icon>
            </div>
        </div>

        <div class="flex flex-row justify-between rounded-2xl border border-slate-200 bg-purple-500 p-6 shadow-sm">
            <div>
                <p class="text-base font-medium text-white">Kar Oranı</p>
                <p class="mt-3 text-3xl font-bold text-white">%@satisRaporu.KarOrani.Deger.ToString("N2")</p>

                <div class="mt-2 flex flex-row items-center justify-start gap-3">
                    <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-white/20">
                        <icon name="@satisRaporu.KarOrani.Icon" class="h-6 w-6 text-white"></icon>
                    </div>

                    <p class="text-sm font-medium text-white">
                        %@Math.Abs(satisRaporu.KarOrani.DegisimOrani).ToString("N1")
                    </p>
                </div>

                <p class="text-sm font-medium text-white">Geçen döneme göre</p>
            </div>

            <div class="flex h-14 w-14 items-center justify-center rounded-full bg-white/20">
                <icon name="percent" class="h-6 w-6 text-white"></icon>
            </div>
        </div>

    </div>

    <section id="CiroRaporu" class="my-12 scroll-mt-24">
        @await Html.PartialAsync("SatisRaporu", Model.SatisRaporu)
    </section>
    <section id="UrunKarlilikRaporu" class="my-12 scroll-mt-24">
        @await Html.PartialAsync("UrunKarlilik", Model.UrunKarlilik)
    </section>
    <section id="MusteriKarlilikRaporu" class="my-12 scroll-mt-24">
        @await Html.PartialAsync("MusteriKarlilik", Model.MusteriKarlilik)
    </section>

</div>





