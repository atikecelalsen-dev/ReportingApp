@model Reporting.Models.InventoryReportViewModel

@{
}

<div class="px-4 pb-8 md:px-24 md:pb-16">
    <section id="toplamStoklar" class="my-12 scroll-mt-24"> 

    <div class="my-8">
        <h1 class="kirmizi-baslik">Envanter Raporları</h1>
        <p class="mt-1 text-sm text-slate-500">
            Mevcut stoklar, stok değerleri ve kritik stok durumu.
        </p>
    </div>

    <div class="mb-8 grid grid-cols-1 gap-4 md:grid-cols-4">
        <div class="flex flex-row justify-between rounded-2xl border border-slate-200 bg-green-500 p-6 shadow-sm">
            <div>
                <p class="text-base font-medium text-white">Toplam Stok Değeri</p>
                <p class="mt-3 text-3xl font-bold text-white">@Model.ToplamStokDegeri.ToString("N2") ₺</p>
            </div>

            <div class="flex h-14 w-14 items-center justify-center rounded-full bg-white/20">
                <icon name="money" class="h-6 w-6 text-white"></icon>
            </div>
        </div>

        <div class="flex flex-row justify-between rounded-2xl border border-slate-200 bg-blue-500 p-6 shadow-sm">
            <div>
                <p class="text-base font-medium text-white">Toplam Ürün</p>
                <p class="mt-3 text-3xl font-bold text-white">@Model.ToplamUrunSayisi</p>
            </div>

            <div class="flex h-14 w-14 items-center justify-center rounded-full bg-white/20">
                <icon name="warehouse" class="h-6 w-6 text-white"></icon>
            </div>
        </div>

        <div class="flex flex-row justify-between rounded-2xl border border-slate-200 bg-amber-500 p-6 shadow-sm">
            <div>
                <p class="text-base font-medium text-white">Kritik Stok</p>
                <p class="mt-3 text-3xl font-bold text-white">@Model.KritikStokSayisi</p>
            </div>

            <div class="flex h-14 w-14 items-center justify-center rounded-full bg-white/20">
                <icon name="trend-down" class="h-6 w-6 text-white"></icon>
            </div>
        </div>

        <div class="flex flex-row justify-between rounded-2xl border border-slate-200 bg-red-500 p-6 shadow-sm">
            <div>
                <p class="text-base font-medium text-white">Stok Yok</p>
                <p class="mt-3 text-3xl font-bold text-white">@Model.StokYokSayisi</p>
            </div>

            <div class="flex h-14 w-14 items-center justify-center rounded-full bg-white/20">
                <icon name="warning-triangle" class="h-6 w-6 text-white"></icon>
            </div>
        </div>

    </div>
    </section>
    
   


    <section id="stokListesi" class="my-12 scroll-mt-24">
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <div class="mb-5 flex items-center justify-between">
            <h2 class="text-lg font-bold text-slate-900">Stok Detayları</h2>
            <span class="text-sm text-slate-500">
                @Model.Stoklar.Count ürün
            </span>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b bg-slate-50 text-left text-xs text-black uppercase">
                        <th class="p-3">Ürün Kodu</th>
                        <th class="p-3">Ürün Adı</th>
                        <th class="p-3 text-right">Giren</th>
                        <th class="p-3 text-right">Çıkan</th>
                        <th class="p-3 text-right">Mevcut Stok</th>
                        <th class="p-3 text-right">Ort. Maliyet</th>
                        <th class="p-3 text-right">Stok Değeri</th>
                        <th class="p-3 text-right">Durum</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model.Stoklar)
                    {
                        string durumClass =
                            item.StokDurumu == "Stok Yok"
                                ? "bg-rose-100 text-rose-700"
                                : item.StokDurumu == "Kritik"
                                    ? "bg-amber-100 text-amber-700"
                                    : "bg-emerald-100 text-emerald-700";

                        <tr class="border-b last:border-0 hover:bg-slate-50">
                            <td class="p-3 font-medium text-slate-700">@item.StokKodu</td>
                            <td class="p-3 font-semibold">@item.StokAdi</td>
                            <td class="p-3 text-right">@item.GirenMiktar.ToString("N2")</td>
                            <td class="p-3 text-right">@item.CikanMiktar.ToString("N2")</td>
                            <td class="!bg-white p-3 text-right @durumClass font-semibold">@item.MevcutStok.ToString("N2")</td>
                            <td class="p-3 text-right">@item.OrtalamaMaliyet.ToString("N2") ₺</td>
                            <td class="p-3 text-right font-semibold">@item.StokDegeri.ToString("N2") ₺</td>
                            <td class="p-3 text-right">
                                <span class="rounded-full px-3 py-1 text-xs font-semibold @durumClass">
                                    @item.StokDurumu
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    </section>

   

</div>